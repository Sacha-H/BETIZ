if (alarm[1] < 0){
    hp -= other.damage
    if (snd_enemy = lession_lession)
        audio_play_sound(snd_enemy,1,false,5);
    if (snd_enemy = hwahwa)
        audio_play_sound(snd_enemy,1,false,4);
    else {
    audio_play_sound(snd_enemy,1,false,2)
    }
    image_blend = c_red
    
    kb_x = sign(x - other.x)
    kb_y = sign(y - other.y)
    alarm[1] =20
}